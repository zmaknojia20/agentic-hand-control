# ── Local hardware mode (default) ───────────────────────────────────────────
# Talks to a real Arduino over serial and a local Ollama model.
# ARDUINO_PORT=/dev/cu.usbmodem1401   # auto-detected if omitted
# BAUD_RATE=9600
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# MODEL_NAME=gemma4:e2b-mlx

# ── Public demo mode ────────────────────────────────────────────────────────
# Simulated "virtual hand" (no Arduino), browser-side camera, hosted LLM.
# DEMO_MODE=1
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your_groq_key_here
# MODEL_NAME=llama-3.3-70b-versatile
